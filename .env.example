# ==========================================
# RAG Design Patterns — API Keys Template
# ==========================================

# 1. Groq (Free, Fast LLM) - Used in ALL patterns
# Get key here: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# 2. Cohere Rerank API (Optional alternative for Pattern 2)
# Get key here: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key_here

# 3. Neo4j Graph DB (Optional production alternative for Patterns 4 & 5)
# Set up locally via Docker or Neo4j Aura Cloud
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# 4. Tavily Web Search API (Used in Patterns 6 & 7)
# Get key here: https://tavily.com/
TAVILY_API_KEY=tvly_your_tavily_key_here
